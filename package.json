{
  "name": "pivotly",
  "type": "module",
  "version": "0.0.1",
  "description": "Modern pivot table component for web.",
  "author": "Derevyankin Denis <derevyankindenis@mail.ru>",
  "license": "MIT",
  "homepage": "https://github.com/derevyankindenis/pivotly#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derevyankindenis/pivotly.git"
  },
  "bugs": {
    "url": "https://github.com/derevyankindenis/pivotly/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "cli-table3": "^0.6.5"
  }
}
